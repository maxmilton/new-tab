{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "extends": [
    "./node_modules/@maxmilton/oxlint-config/recommended.json",
    "./node_modules/@maxmilton/oxlint-config/stage1.json"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "pedantic": "warn",
    "perf": "error",
    "style": "warn",
    "restriction": "error",
    "nursery": "warn"
  },
  "env": {
    "browser": true,
    "builtin": true,
    "es2025": true,
    "webextensions": true
  },
  "globals": {
    "Bun": "readonly",
    "process": "readonly"
  },
  "rules": {
    "eslint/id-length": [
      "error",
      {
        "exceptionPatterns": ["^[A-Z]$"], // single uppercase letter type names
        "exceptions": ["_", /* UserStorageData keys */ "n", "t", "b", "o", "s"]
      }
    ],

    /* Performance and byte savings */
    "eslint/prefer-template": "off",
    "promise/prefer-await-to-callbacks": "off", // control resolve timing for better performance
    "promise/prefer-await-to-then": "off",
    "unicorn/explicit-length-check": "off", // byte savings + faster
    "unicorn/no-array-for-each": "off", // forEach is more compact (slower but; for non-performance-critical code)
    "unicorn/no-array-sort": "off", // faster to mutate arrays in place
    "unicorn/no-await-expression-member": "off",
    "unicorn/prefer-includes": "off", // indexOf is faster in some cases
    "unicorn/prefer-native-coercion-functions": "off", // arrow function saves 3 bytes
    "unicorn/prefer-string-starts-ends-with": "off" // byte savings + faster
  },
  "overrides": [
    {
      "files": ["test/**"],
      "globals": {
        "$console": "readonly",
        "happyDOM": "readonly",
        "Loader": "readonly"
      }
    },
    {
      "files": ["src/sw.ts"],
      "env": {
        "serviceworker": true
      }
    }
  ]
}
